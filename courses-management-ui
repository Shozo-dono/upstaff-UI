    <script>
        (function () {
            // ----- DOM elements -----
            const searchInput = document.getElementById('searchInput');
            const statusSelect = document.getElementById('statusSelect');
            const filterBtn = document.getElementById('filterBtn');
            const filterDropdown = document.getElementById('filterDropdown');
            const closeDropdownBtn = document.getElementById('closeDropdownBtn');
            const applyFiltersBtn = document.getElementById('applyFiltersBtn');
            const clearFiltersBtn = document.getElementById('clearFiltersBtn');
            const filterBadge = document.getElementById('filterBadge');
            const visibleCountSpan = document.getElementById('visibleCount');

            // All filter checkbox groups
            const categoryCheckboxes = () => Array.from(document.querySelectorAll('.category-filter'));
            const difficultyCheckboxes = () => Array.from(document.querySelectorAll('.difficulty-filter'));
            const statusCheckboxes = () => Array.from(document.querySelectorAll('.status-filter'));

            // Applied filters state (active after clicking "Apply filters")
            let appliedFilters = {
                categories: [],     // e.g., ['Security & IT', 'Design']
                difficulties: [],   // ['Beginner', 'Advanced']
                statuses: []        // ['Published', 'Draft']
            };

            // ---------- Helper: filter courses based on current search, main status dropdown & appliedFilters ----------
            function filterCoursesAndUpdateUI() {
                const searchTerm = searchInput.value.trim().toLowerCase();
                const mainStatusValue = statusSelect.value;  // "" | "Published" | "Draft"
                const courseItems = document.querySelectorAll('.course-item');
                let visibleCount = 0;

                courseItems.forEach(course => {
                    const titleElem = course.querySelector('h3');
                    const title = titleElem ? titleElem.textContent.toLowerCase() : '';
                    const category = course.dataset.category || '';
                    const difficulty = course.dataset.difficulty || '';
                    const status = course.dataset.status || '';

                    // 1) search match
                    const matchesSearch = title.includes(searchTerm);
                    // 2) main status dropdown match
                    const matchesMainStatus = !mainStatusValue || status === mainStatusValue;
                    // 3) applied category filter (if any)
                    const matchesCategory = appliedFilters.categories.length === 0 || appliedFilters.categories.includes(category);
                    // 4) applied difficulty filter
                    const matchesDifficulty = appliedFilters.difficulties.length === 0 || appliedFilters.difficulties.includes(difficulty);
                    // 5) applied status filter (from filter panel)
                    const matchesStatusFilter = appliedFilters.statuses.length === 0 || appliedFilters.statuses.includes(status);

                    if (matchesSearch && matchesMainStatus && matchesCategory && matchesDifficulty && matchesStatusFilter) {
                        course.classList.remove('hidden');
                        visibleCount++;
                    } else {
                        course.classList.add('hidden');
                    }
                });

                visibleCountSpan.textContent = visibleCount;
                updateFilterBadge();
            }

            // Update badge count (sum of applied filter selections)
            function updateFilterBadge() {
                const total = appliedFilters.categories.length + appliedFilters.difficulties.length + appliedFilters.statuses.length;
                if (total > 0) {
                    filterBadge.textContent = total;
                    filterBadge.classList.remove('hidden');
                } else {
                    filterBadge.classList.add('hidden');
                }
            }

            // ----- Sync dropdown checkboxes with current appliedFilters (when opening)
            function syncDropdownWithAppliedFilters() {
                // categories
                categoryCheckboxes().forEach(cb => {
                    cb.checked = appliedFilters.categories.includes(cb.value);
                });
                // difficulties
                difficultyCheckboxes().forEach(cb => {
                    cb.checked = appliedFilters.difficulties.includes(cb.value);
                });
                // statuses
                statusCheckboxes().forEach(cb => {
                    cb.checked = appliedFilters.statuses.includes(cb.value);
                });
            }

            // Read current state from dropdown checkboxes (without applying)
            function getFiltersFromDropdown() {
                return {
                    categories: categoryCheckboxes().filter(cb => cb.checked).map(cb => cb.value),
                    difficulties: difficultyCheckboxes().filter(cb => cb.checked).map(cb => cb.value),
                    statuses: statusCheckboxes().filter(cb => cb.checked).map(cb => cb.value)
                };
            }

            // Apply filters from dropdown -> update appliedFilters -> re-filter & close dropdown
            function applyFiltersFromDropdown() {
                const newFilters = getFiltersFromDropdown();
                appliedFilters = { ...newFilters };
                filterCoursesAndUpdateUI();
                closeDropdown();
            }

            // Clear all filters (both UI checkboxes and applied state)
            function clearAllFilters() {
                // Uncheck all checkboxes inside dropdown
                categoryCheckboxes().forEach(cb => cb.checked = false);
                difficultyCheckboxes().forEach(cb => cb.checked = false);
                statusCheckboxes().forEach(cb => cb.checked = false);
                // Reset appliedFilters state
                appliedFilters = { categories: [], difficulties: [], statuses: [] };
                // Re-filter courses & update badge
                filterCoursesAndUpdateUI();
                // Optionally keep dropdown open? stays open for next actions.
                // But badge updated.
            }

            // ---------- Dropdown controls ----------
            function openDropdown() {
                // Before opening, sync checkboxes with currently applied filters
                syncDropdownWithAppliedFilters();
                filterDropdown.classList.add('open');
            }

            function closeDropdown() {
                filterDropdown.classList.remove('open');
            }

            function toggleDropdown() {
                if (filterDropdown.classList.contains('open')) {
                    closeDropdown();
                } else {
                    openDropdown();
                }
            }

            // ----- Event listeners -----
            filterBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                toggleDropdown();
            });

            closeDropdownBtn.addEventListener('click', () => {
                closeDropdown();
            });

            applyFiltersBtn.addEventListener('click', (e) => {
                e.preventDefault();
                applyFiltersFromDropdown();
            });

            clearFiltersBtn.addEventListener('click', (e) => {
                e.preventDefault();
                clearAllFilters();
                // after clearing, we also keep dropdown open? usually stays open to see cleared state.
                // But to improve UX we re-sync checkboxes (already cleared inside clearAllFilters)
                // however we might also need to re-sync because appliedFilters is empty now
                // but checkboxes are already unchecked. Perfect.
                // Additional small: after clearing, we keep dropdown open but reflect empty selections.
            });

            // Search & main status select: re-filter with current appliedFilters instantly
            searchInput.addEventListener('input', () => {
                filterCoursesAndUpdateUI();
            });
            statusSelect.addEventListener('change', () => {
                filterCoursesAndUpdateUI();
            });

            // Click outside to close dropdown
            document.addEventListener('click', (e) => {
                if (filterDropdown && filterBtn && !filterDropdown.contains(e.target) && !filterBtn.contains(e.target)) {
                    if (filterDropdown.classList.contains('open')) {
                        closeDropdown();
                    }
                }
            });

            // Escape key closes dropdown
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && filterDropdown.classList.contains('open')) {
                    closeDropdown();
                }
            });

            // Prevent dropdown internal clicks from bubbling to outside close
            filterDropdown.addEventListener('click', (e) => e.stopPropagation());

            // Initial render: no active filters, all courses visible
            // Also ensure hidden class removed initially (all visible)
            (function initialize() {
                appliedFilters = { categories: [], difficulties: [], statuses: [] };
                filterCoursesAndUpdateUI();
                // make sure any course hidden class reset (already handled)
                // badge will be hidden because total = 0
                // also ensure dropdown checkboxes start unchecked.
                syncDropdownWithAppliedFilters();
            })();
        })();
    </script>
</body>

</html>
